---
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/bricolage-grotesque/opsz.css';

interface Props {
  title?: string;
  description?: string;
  autoLocaleRedirect?: boolean;
}

const lang = (Astro.currentLocale ?? 'es') as 'es' | 'en';

const defaults = {
  es: {
    title: 'Parmelia — Mueve dinero digital como mandar un mensaje',
    description:
      'Cobra con links, paga con QR y envía a usernames. Mover dinero digital, fácil para ti y para quien recibe. Sin descargar apps, sin comisiones entre usuarios.',
  },
  en: {
    title: 'Parmelia — Move digital money like sending a message',
    description:
      'Charge with links, pay with QR and send to usernames. Moving digital money, easy for you and whoever receives it. No app downloads, no fees between users.',
  },
} as const;

const {
  title = defaults[lang].title,
  description = defaults[lang].description,
  autoLocaleRedirect = false,
} = Astro.props;

const siteUrl = 'https://parmelia.me/';
const englishUrl = new URL('/en/', siteUrl).href;
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL('/og.png', siteUrl).href;
const ogLocale = lang === 'en' ? 'en_US' : 'es_ES';
const ogImageAlt =
  lang === 'en'
    ? 'Parmelia — move digital money like sending a message'
    : 'Parmelia — mueve dinero digital como mandar un mensaje';

// Privacy-friendly analytics, off by default. Enable by setting
// PUBLIC_PLAUSIBLE_DOMAIN (e.g. "parmelia.me") in the environment / .env.
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#org`,
      name: 'Parmelia',
      url: siteUrl,
      logo: new URL('/Logo_parmelia.svg', siteUrl).href,
      sameAs: ['https://x.com/parmelia_'],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'Parmelia',
      inLanguage: lang,
      publisher: { '@id': `${siteUrl}#org` },
    },
    {
      '@type': 'WebApplication',
      name: 'Parmelia',
      url: 'https://app.parmelia.me',
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Web',
      description,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {
      autoLocaleRedirect && (
        <script
          is:inline
          set:html={`
            (() => {
              const preferenceKey = 'parmelia:preferred-locale';
              const currentLocale = '${lang}';
              const readPreference = () => {
                try {
                  const value = window.localStorage.getItem(preferenceKey);
                  return value === 'es' || value === 'en' ? value : null;
                } catch {
                  return null;
                }
              };
              const configuredLanguages =
                Array.isArray(navigator.languages) && navigator.languages.length
                  ? navigator.languages
                  : [navigator.language || ''];
              const primaryLanguage = String(configuredLanguages[0] || '').toLowerCase();
              const targetLocale = readPreference() ?? (primaryLanguage.startsWith('es') ? 'es' : 'en');

              if (targetLocale !== currentLocale) {
                const nextUrl = new URL(targetLocale === 'es' ? '/' : '/en/', window.location.origin);
                nextUrl.search = window.location.search;
                nextUrl.hash = window.location.hash;
                window.location.replace(nextUrl.href);
              }
            })();
          `}
        />
      )
    }
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical + language alternates -->
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Parmelia" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@parmelia_" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme color for mobile browser chrome -->
    <meta name="theme-color" content="#0A0A0B" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

    {
      plausibleDomain && (
        <Fragment>
          <script
            defer
            data-domain={plausibleDomain}
            src="https://plausible.io/js/script.outbound-links.js"
            is:inline
          />
          <script is:inline>
            window.plausible = window.plausible || function () {(window.plausible.q = window.plausible.q || []).push(arguments)}
          </script>
        </Fragment>
      )
    }

    <!-- Gate scroll-reveal hiding behind JS availability: without JS the page stays fully visible -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
