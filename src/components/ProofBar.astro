---
import { Image } from 'astro:assets';
import monadLogo from '../assets/monad-clean.png';

const stats = [
  { value: '0%', label: 'Comisiones entre usuarios' },
  { value: '100%', label: 'Tu dinero, siempre tuyo' },
  { value: '3', label: 'Activos: USDC, MON y WBTC' },
];
---

<section id="proof" class="proof-bar" data-reveal>
  <div class="proof-inner">
    {stats.map((s) => (
      <div class="proof-stat">
        <span class="proof-value">{s.value}</span>
        <span class="proof-label">{s.label}</span>
      </div>
    ))}
    <div class="proof-stat proof-built">
      <Image src={monadLogo} alt="Monad" width={68} height={68} loading="lazy" decoding="async" />
      <span class="proof-label">Construido sobre Monad</span>
    </div>
  </div>

  <p class="proof-note">Pensado para mover dólares digitales en Bolivia y LATAM.</p>
</section>
