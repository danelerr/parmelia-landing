---
const tags = ['Freelancers', 'Eventos', 'Comunidades', 'Ventas por DM'];
---

<section id="payment-links" class="landing-section" style="background-color: var(--color-pink);">
  <div class="landing-shell">
    <div class="copy-stack" data-reveal>
      <span class="section-eyebrow">Links de pago</span>
      <h2 class="section-title">Cobra donde quieras, fácilmente.</h2>
      <p class="section-copy">
        Genera un link, compártelo por WhatsApp, Telegram, Instagram o X, y recibe el pago sin explicar redes, gas ni direcciones.
      </p>
    </div>

    <div class="visual-panel payment-panel" data-reveal>
      <p class="payment-url">
        app.parmelia.me/pay
      </p>
      <p class="mx-auto text-center text-lg font-bold text-[#121212]/50">25 USDC para cobrar ahora</p>

      <svg class="payment-transfer" viewBox="0 0 360 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g transform="translate(28 22) scale(.36)">
          <path d="M83.3377 0.820332L0.328533 58.6046L8.32585 64.2196L85.1075 118.216L162.136 64.6112L170.082 59.0738L87.3243 0.832505C86.0859 0.0162387 84.5791 0.00937285 83.3377 0.820332Z" fill="#A7D4DE"/>
          <path d="M86.8349 125.155C85.7498 125.866 84.4312 125.863 83.3487 125.146L7.21886 72.2561L0.265018 67.4362L0.196435 98.6944L7.15101 103.514L85.0306 157.652L163.105 103.911L170.078 99.095L170.137 67.8895L163.164 72.6739L86.8349 125.155Z" fill="#DEA6BC"/>
          <path d="M86.7497 164.587C85.6645 165.298 84.3459 165.295 83.2635 164.578L7.13366 111.688L0.179813 106.869L0.11123 138.127L7.0658 142.947L84.9454 197.085L163.02 143.344L169.993 138.527L170.052 107.322L163.079 112.106L86.7497 164.587Z" fill="#DED9A6"/>
        </g>
        <line x1="108" y1="58" x2="252" y2="58" stroke="#121212" stroke-opacity=".18" stroke-width="3" stroke-dasharray="8 8" />
        <circle class="p2p-transfer-dot" cx="108" cy="58" r="9" />
        <g transform="translate(260 22) scale(.36)">
          <path d="M83.3377 0.820332L0.328533 58.6046L8.32585 64.2196L85.1075 118.216L162.136 64.6112L170.082 59.0738L87.3243 0.832505C86.0859 0.0162387 84.5791 0.00937285 83.3377 0.820332Z" fill="#A7D4DE"/>
          <path d="M86.8349 125.155C85.7498 125.866 84.4312 125.863 83.3487 125.146L7.21886 72.2561L0.265018 67.4362L0.196435 98.6944L7.15101 103.514L85.0306 157.652L163.105 103.911L170.078 99.095L170.137 67.8895L163.164 72.6739L86.8349 125.155Z" fill="#DEA6BC"/>
          <path d="M86.7497 164.587C85.6645 165.298 84.3459 165.295 83.2635 164.578L7.13366 111.688L0.179813 106.869L0.11123 138.127L7.0658 142.947L84.9454 197.085L163.02 143.344L169.993 138.527L170.052 107.322L163.079 112.106L86.7497 164.587Z" fill="#DED9A6"/>
        </g>
      </svg>
    </div>

    <div class="pill-row" data-reveal-stagger>
      {tags.map((tag) => (
        <span class="pill">{tag}</span>
      ))}
    </div>
  </div>
</section>
