---
import { getLang } from '../i18n';

const lang = getLang(Astro.currentLocale);
const t = {
  es: {
    title: 'Haz que tu saldo trabaje por ti.',
    copy: 'Tu dinero puede generar rendimiento mientras no lo usas, y vuelve a estar listo para pagar cuando lo necesites.',
    micro: 'Rendimientos variables. Siempre bajo tu decisión.',
    points: [
      'Activas Earn cuando el saldo puede esperar.',
      'Ves el movimiento sin salir de Parmelia.',
      'Retiras cuando lo necesites para pagar o enviar.',
    ],
  },
  en: {
    title: 'Put your balance to work for you.',
    copy: 'Your money can earn yield while you’re not using it, and it’s ready to pay again whenever you need it.',
    micro: 'Variable yields. Always your decision.',
    points: [
      'You turn on Earn when your balance can wait.',
      'You see the movement without leaving Parmelia.',
      'You withdraw whenever you need to pay or send.',
    ],
  },
}[lang];
const points = t.points;
---

<section id="earn" class="landing-section earn-gradient">
  <div class="landing-shell">
    <div class="copy-stack" data-reveal>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-copy">{t.copy}</p>
    </div>

    <div class="earn-panel" data-reveal>
      <svg class="earn-orbit" viewBox="0 0 200 230" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- rising yield -->
        <circle class="gas-particle" cx="100" cy="62" r="6" fill="#EFE08C" />
        <circle class="gas-particle" cx="76" cy="74" r="4" fill="#9CE3F4" />
        <circle class="gas-particle" cx="124" cy="70" r="5" fill="#F4A9CF" />
        <!-- growing stack -->
        <g transform="translate(0, 34)">
          <polygon class="stake-layer" points="100,120 170,155 100,190 30,155" fill="rgba(255,255,255,.1)" />
          <polygon class="stake-layer" points="100,90 170,125 100,160 30,125" fill="#A7D4DE" />
          <polygon class="stake-layer" points="100,60 170,95 100,130 30,95" fill="#DEA6BC" />
          <polygon class="stake-layer" points="100,30 170,65 100,100 30,65" fill="#DED9A6" />
        </g>
      </svg>

      <div class="earn-copy">
        {points.map((point, index) => (
          <div class="earn-point">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{point}</p>
          </div>
        ))}
      </div>
    </div>

    <p class="microcopy mt-10" data-reveal>{t.micro}</p>
  </div>
</section>
