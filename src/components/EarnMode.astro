---
const points = [
  'Activas Earn cuando el saldo puede esperar.',
  'Ves el movimiento sin salir de Parmelia.',
  'Retiras cuando lo necesites para pagar o enviar.',
];
---

<section id="earn" class="landing-section earn-gradient dark-field">
  <div class="landing-shell">
    <div class="copy-stack" data-reveal>
      <span class="section-eyebrow dark">Earn mode</span>
      <h2 class="section-title dark">Haz que tu saldo trabaje sin perder control.</h2>
      <p class="section-copy dark">
        Earn vive dentro del mismo flujo: tu dinero se mueve, se guarda o vuelve a estar listo para pagar cuando tú decides.
      </p>
    </div>

    <div class="earn-panel" data-reveal>
      <svg class="earn-orbit" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g transform="translate(10, 8)">
          <polygon points="100,60 140,80 100,100 60,80" fill="#A7D4DE" />
          <path d="M60,94 L100,114 L140,94 L140,112 L100,132 L60,112 Z" fill="#DEA6BC" />
          <path d="M60,124 L100,144 L140,124 L140,142 L100,162 L60,142 Z" fill="#DED9A6" />
          <g class="orbit-container" style="transform-origin: 100px 94px;">
            <circle cx="100" cy="20" r="8" fill="#DEA6BC" class="orbit-node" style="transform-origin: 100px 20px;" />
            <circle cx="166" cy="134" r="7" fill="#DED9A6" class="orbit-node" style="transform-origin: 166px 134px;" />
            <circle cx="36" cy="134" r="9" fill="#FFFFFF" class="orbit-node" style="transform-origin: 36px 134px;" />
          </g>
          <path d="M100 20 C158 46 178 120 136 164 C97 204 26 168 36 108 C45 54 88 33 100 20Z" fill="none" stroke="rgba(255,255,255,.16)" stroke-width="2" />
        </g>
      </svg>

      <div class="earn-copy">
        {points.map((point, index) => (
          <div class="earn-point">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{point}</p>
          </div>
        ))}
      </div>
    </div>

    <p class="microcopy dark mt-10" data-reveal>
      Rendimientos variables. Nunca se comunican como promesa fija.
    </p>
  </div>
</section>
