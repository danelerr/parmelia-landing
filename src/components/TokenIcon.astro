---
import { Image } from 'astro:assets';
import usdcLogo from '../assets/Circle_USDC_Logo.svg.png';
import ethLogo from '../assets/eth-round.png';
import wbtcLogo from '../assets/Bitcoin.svg.png';

interface Props {
  token: 'USDC' | 'ETH' | 'WBTC';
  className?: string;
}

const { token, className = '' } = Astro.props;

const meta = {
  USDC: { src: usdcLogo, label: 'USDC' },
  ETH: { src: ethLogo, label: 'Ethereum (ETH)' },
  WBTC: { src: wbtcLogo, label: 'Wrapped Bitcoin (WBTC)' },
} as const;

const { src, label } = meta[token];
---

<span class={`token-logo token-${token.toLowerCase()} ${className}`} aria-label={label} role="img">
  <Image src={src} alt={label} width={140} height={140} loading="lazy" decoding="async" />
</span>
