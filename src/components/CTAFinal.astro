---
import { getLang } from '../i18n';

const lang = getLang(Astro.currentLocale);
const t = {
  es: {
    title: 'Empieza con tu primer link.',
    copy: 'Abre Parmelia, comparte tu link y empieza a mover dinero digital tan fácil como mandar un mensaje.',
    cta: 'Probar Parmelia',
    ctaLink: 'Crear link de pago',
    buildLead: 'Lo estamos construyendo en público.',
    follow: 'Síguenos en X',
    buildTail: 'y mira cómo avanza.',
  },
  en: {
    title: 'Start with your first link.',
    copy: 'Open Parmelia, share your link and start moving digital money as easily as sending a message.',
    cta: 'Try Parmelia',
    ctaLink: 'Create a payment link',
    buildLead: 'We’re building it in public.',
    follow: 'Follow us on X',
    buildTail: 'and watch it progress.',
  },
}[lang];
---

<section id="cta-final" class="landing-section relative" style="background-color: var(--color-black);">
  <svg class="absolute inset-0 h-full w-full opacity-60" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g stroke="#1a1a1a" stroke-width="2" fill="none">
      <path d="M -100,100 L 300,300 L 500,200 L 800,350 L 1100,200" />
      <path d="M -100,500 L 200,350 L 400,450 L 700,300 L 1100,500" />
      <path d="M 100,-100 L 400,200 L 400,400 L 600,500 L 900,350 L 1100,450" />
      <path d="M 300,300 L 400,200" />
      <path d="M 500,200 L 700,300" />
      <path d="M 400,450 L 400,400" />
    </g>
    <path class="data-stream stream-sky" d="M -100,100 L 300,300 L 500,200 L 800,350 L 1100,200" />
    <path class="data-stream stream-pink" d="M -100,500 L 200,350 L 400,450 L 700,300 L 1100,500" />
    <path class="data-stream stream-cream" d="M 100,-100 L 400,200 L 400,400 L 600,500 L 900,350 L 1100,450" />
  </svg>

  <div class="landing-shell">
    <div class="copy-stack" data-reveal>
      <h2 class="section-title dark">{t.title}</h2>
      <p class="section-copy dark">{t.copy}</p>

      <div class="button-row">
        <a href="https://app.parmelia.me?ref=landing_cta" target="_blank" rel="noopener noreferrer" class="btn-primary light" data-cta="cta_final_primary">
          {t.cta}
        </a>
        <a href="https://app.parmelia.me?ref=landing_cta_link" target="_blank" rel="noopener noreferrer" class="btn-gradient" data-cta="cta_final_link">
          {t.ctaLink}
        </a>
      </div>

      <p class="build-note">
        <span class="build-pulse" aria-hidden="true"></span>
        {t.buildLead}
        <a href="https://x.com/parmelia_" target="_blank" rel="noopener noreferrer" data-cta="follow_x">{t.follow}</a>
        {t.buildTail}
      </p>
    </div>
  </div>
</section>
