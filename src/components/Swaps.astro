---
import TokenIcon from './TokenIcon.astro';
import { getLang } from '../i18n';

const lang = getLang(Astro.currentLocale);
const t = {
  es: {
    title: 'Cambia cuando el pago lo necesita.',
    copy: 'Convierte entre activos sin salir de Parmelia. Menos pestañas, menos pasos y menos margen para equivocarte.',
  },
  en: {
    title: 'Swap when the payment needs it.',
    copy: 'Convert between assets without leaving Parmelia. Fewer tabs, fewer steps and less room for mistakes.',
  },
}[lang];

const swaps = [
  { from: 'USDC', to: 'ETH' },
  { from: 'ETH', to: 'USDC' },
  { from: 'USDC', to: 'WBTC' },
] as const;
---

<section id="swaps" class="landing-section">
  <div class="landing-shell">
    <div class="split" data-reveal>
      <div class="split-copy">
        <h2 class="section-title">{t.title}</h2>
        <p class="section-copy">{t.copy}</p>
      </div>

      <div class="split-visual">
        <div class="w-full max-w-[420px] flex flex-col gap-3" data-reveal-stagger>
          {swaps.map((swap) => (
            <article class="feature-card swap-row">
              <span class="flex items-center gap-3">
                <TokenIcon token={swap.from} className="!w-11 !h-11" />
                <span class="card-title text-[19px]">{swap.from}</span>
              </span>
              <span class="swap-divider">
                <span class="transfer-dot block h-3 w-3 rounded-full"></span>
              </span>
              <span class="flex items-center gap-3">
                <TokenIcon token={swap.to} className="!w-11 !h-11" />
                <span class="card-title text-[19px]">{swap.to}</span>
              </span>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
