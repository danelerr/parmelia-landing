---
/*
  Animated monospace character field for the hero background.
  Self-contained: own <canvas>, scoped <style>, no global styles, no deps,
  pointer-events:none, respects prefers-reduced-motion, pauses off-screen.
  Sits BEHIND hero content (landing-shell is z-index 1).
*/
---

<canvas class="hero-backdrop" aria-hidden="true"></canvas>

<style>
  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.6;
    -webkit-mask-image: radial-gradient(125% 95% at 50% 16%, #000 28%, transparent 80%);
    mask-image: radial-gradient(125% 95% at 50% 16%, #000 28%, transparent 80%);
  }
</style>

<script>
  const canvasEl = document.querySelector<HTMLCanvasElement>('canvas.hero-backdrop');
  const ctxEl = canvasEl?.getContext('2d') ?? null;
  const hostEl = canvasEl?.parentElement ?? null;
  if (canvasEl && ctxEl && hostEl) {
    {
      const canvas: HTMLCanvasElement = canvasEl;
      const ctx: CanvasRenderingContext2D = ctxEl;
      const host: HTMLElement = hostEl;
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const glyphs = ['+', '·', '/', '\\', 'x', '=', '*', 'o', ':'];
      const brand = [
        [167, 212, 222], // sky
        [222, 166, 188], // pink
        [222, 217, 166], // cream
      ];
      const cell = 18;
      let cols = 0;
      let rows = 0;
      let t = 0;
      let raf = 0;
      let glyphMap: string[] = [];

      function resize() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const w = host.clientWidth;
        const h = host.clientHeight;
        if (!w || !h) return;
        canvas.width = Math.floor(w * dpr);
        canvas.height = Math.floor(h * dpr);
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        cols = Math.ceil(w / cell);
        rows = Math.ceil(h / cell);
        glyphMap = new Array(cols * rows);
        for (let i = 0; i < glyphMap.length; i++) {
          glyphMap[i] = glyphs[(Math.random() * glyphs.length) | 0];
        }
        ctx.font = '12px ui-monospace, SFMono-Regular, Menlo, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
      }

      function render() {
        ctx.clearRect(0, 0, host.clientWidth, host.clientHeight);
        for (let y = 0; y < rows; y++) {
          for (let x = 0; x < cols; x++) {
            const wave = Math.sin(x * 0.32 + y * 0.22 - t);
            if (wave < 0.12) continue;
            const a = (wave - 0.12) / 0.88;
            let r = 255, g = 255, b = 255, alpha = 0.04 + a * 0.16;
            if (wave > 0.9) {
              const c = brand[(x + y) % 3];
              r = c[0]; g = c[1]; b = c[2];
              alpha = 0.25 + (wave - 0.9) * 3;
            }
            ctx.fillStyle = `rgba(${r},${g},${b},${alpha.toFixed(3)})`;
            ctx.fillText(glyphMap[y * cols + x], x * cell + cell / 2, y * cell + cell / 2);
          }
        }
      }

      function loop() {
        render();
        t += 0.018;
        raf = requestAnimationFrame(loop);
      }

      function start() { if (!raf) raf = requestAnimationFrame(loop); }
      function stop() { if (raf) { cancelAnimationFrame(raf); raf = 0; } }

      resize();
      let resizeTimer = 0;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          resize();
          if (reduce) render();
        }, 150);
      });

      if (reduce) {
        render();
      } else {
        const io = new IntersectionObserver((entries) => {
          entries[0].isIntersecting ? start() : stop();
        });
        io.observe(host);
        start();
      }
    }
  }
</script>
