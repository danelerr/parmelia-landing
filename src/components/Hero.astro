---
import ParmeliaStack from './ParmeliaStack.astro';
import HeroBackdrop from './HeroBackdrop.astro';
---

<section id="hero" class="hero-section hero-dark">
  <HeroBackdrop />

  <div class="landing-shell">
    <div class="copy-stack wide" data-reveal>
      <ParmeliaStack className="hero-logo-glow" />

      <div class="relative w-full">
        <h1 class="hero-title hero-title-light">
          Mueve dinero digital <span class="text-gradient">como mandar un mensaje.</span>
        </h1>
      </div>

      <p class="section-copy">
        Cobra con links, paga con QR y envía a usernames. Fácil para ti, fácil para quien recibe.
      </p>

      <div class="button-row">
        <a href="https://app.parmelia.me" target="_blank" rel="noopener noreferrer" class="btn-parmelia hero-cta">
          Probar Parmelia
        </a>
        <a href="#payment-links" class="btn-ghost">Ver cómo funciona</a>
      </div>

      <p class="microcopy hero-proofline">
        <span>Sin descargar apps</span>
        <span class="proof-dot proof-dot-sky" aria-hidden="true"></span>
        <span>sin frases raras</span>
        <span class="proof-dot proof-dot-pink" aria-hidden="true"></span>
        <span>sin complicaciones</span>
      </p>
    </div>
  </div>
</section>
