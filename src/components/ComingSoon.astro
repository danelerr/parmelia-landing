---
import CardGlyphs from './CardGlyphs.astro';
import { getLang } from '../i18n';

const lang = getLang(Astro.currentLocale);
const t = {
  es: {
    badge: 'Próximamente',
    title: 'Tu dinero digital, también fuera de la app.',
    copy: 'Estamos construyendo una tarjeta conectada a tu saldo y un puente directo con el QR de Bolivia: comprar y pagar con dólares digitales en el mundo real.',
    cardLabel: 'Saldo en USDC',
    points: [
      { dot: 'var(--glow-gold)', title: 'Tarjeta con stablecoins', status: 'En desarrollo', desc: 'Una tarjeta conectada a tu saldo para pagar donde aceptan tarjetas, con tus dólares digitales.' },
      { dot: 'var(--glow-sky)', title: 'Compra con QR boliviano', status: 'En camino', desc: 'Escanea un QR y compra USDC con la plata que ya usas, sin trámites raros.' },
      { dot: 'var(--glow-pink)', title: 'Paga el QR de Bolivia', status: 'En camino', desc: 'Usa tu saldo para pagar el QR de cualquier comercio, al instante.' },
    ],
  },
  en: {
    badge: 'Coming soon',
    title: 'Your digital money, beyond the app too.',
    copy: 'We’re building a card connected to your balance and a direct bridge with Bolivia’s QR: buy and pay with digital dollars in the real world.',
    cardLabel: 'USDC balance',
    points: [
      { dot: 'var(--glow-gold)', title: 'Stablecoin card', status: 'In development', desc: 'A card connected to your balance to pay wherever cards are accepted, with your digital dollars.' },
      { dot: 'var(--glow-sky)', title: 'Buy with Bolivian QR', status: 'On the way', desc: 'Scan a QR and buy USDC with the money you already use, no weird paperwork.' },
      { dot: 'var(--glow-pink)', title: 'Pay any Bolivian QR', status: 'On the way', desc: 'Use your balance to pay the QR of any merchant, instantly.' },
    ],
  },
}[lang];
const points = t.points;
---

<section id="coming" class="landing-section">
  <div class="landing-shell">
    <div class="split" data-reveal>
      <div class="split-copy">
        <span class="soon-badge"><span class="soon-dot" aria-hidden="true"></span> {t.badge}</span>
        <h2 class="section-title">{t.title}</h2>
        <p class="section-copy">{t.copy}</p>

        <div class="point-list" data-reveal-stagger>
          {points.map((point) => (
            <div class="point-row">
              <span class="dot" style={`background:${point.dot}; color:${point.dot};`}></span>
              <p>
                <span class="point-head">
                  <strong style="color:var(--color-text); font-weight:600;">{point.title}</strong>
                  <span class="point-tag">{point.status}</span>
                </span>
                {point.desc}
              </p>
            </div>
          ))}
        </div>
      </div>

      <div class="split-visual">
        <div class="stage glow-pink">
          <div class="stable-card">
            <CardGlyphs />
            <div class="stable-card__top">
              <span class="stable-card__brand">Parmelia</span>
              <svg class="stable-card__wave" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                <path d="M8.5 8.5a5 5 0 0 1 0 7" />
                <path d="M11.5 6a8.5 8.5 0 0 1 0 12" />
                <path d="M14.5 3.5a12 12 0 0 1 0 17" />
              </svg>
            </div>

            <span class="stable-card__chip" aria-hidden="true"></span>

            <div class="stable-card__number" aria-hidden="true">
              <span>5274</span><span>88••</span><span>••••</span><span>0420</span>
            </div>

            <div class="stable-card__bottom">
              <span class="stable-card__col">
                <span class="stable-card__label">{t.cardLabel}</span>
                <span class="stable-card__value">$ 1,240.00</span>
              </span>
              <span class="stable-card__logo" aria-hidden="true">
                <svg viewBox="0 0 171 198" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M83.3377 0.820332L0.328533 58.6046L8.32585 64.2196L85.1075 118.216L162.136 64.6112L170.082 59.0738L87.3243 0.832505C86.0859 0.0162387 84.5791 0.00937285 83.3377 0.820332Z" fill="#A7D4DE"/>
                  <path d="M86.8349 125.155C85.7498 125.866 84.4312 125.863 83.3487 125.146L7.21886 72.2561L0.265018 67.4362L0.196435 98.6944L7.15101 103.514L85.0306 157.652L163.105 103.911L170.078 99.095L170.137 67.8895L163.164 72.6739L86.8349 125.155Z" fill="#DEA6BC"/>
                  <path d="M86.7497 164.587C85.6645 165.298 84.3459 165.295 83.2635 164.578L7.13366 111.688L0.179813 106.869L0.11123 138.127L7.0658 142.947L84.9454 197.085L163.02 143.344L169.993 138.527L170.052 107.322L163.079 112.106L86.7497 164.587Z" fill="#DED9A6"/>
                </svg>
              </span>
            </div>
          </div>

          <div class="rail-hint" aria-hidden="true">
            <span class="rail-node">QR Bs.</span>
            <span class="rail-flow"><span class="rail-dot"></span></span>
            <span class="rail-node">USDC</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
