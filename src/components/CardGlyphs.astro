---
/*
  Static monospace glyph field — a single frozen frame of the hero backdrop,
  rendered into the card face. Same wave/colors as HeroBackdrop, but NO loop,
  NO animation, NO observers: it looks like a screenshot of the hero pasted
  onto the card. Self-contained, pointer-events:none, redraws on resize only.
*/
---

<canvas class="card-glyphs" aria-hidden="true"></canvas>

<style>
  .card-glyphs {
    position: absolute;
    inset: 0;
    z-index: -1; /* above the card's bg gradients, below the card content */
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.5;
    -webkit-mask-image: radial-gradient(135% 130% at 50% 28%, #000 52%, transparent 100%);
    mask-image: radial-gradient(135% 130% at 50% 28%, #000 52%, transparent 100%);
  }
</style>

<script>
  const fields = document.querySelectorAll<HTMLCanvasElement>('canvas.card-glyphs');

  fields.forEach((canvasEl) => {
    const ctxMaybe = canvasEl.getContext('2d');
    const hostMaybe = canvasEl.parentElement;
    if (!ctxMaybe || !hostMaybe) return;

    const canvas: HTMLCanvasElement = canvasEl;
    const ctx: CanvasRenderingContext2D = ctxMaybe;
    const host: HTMLElement = hostMaybe;
    const glyphs = ['+', '·', '/', '\\', 'x', '=', '*', 'o', ':'];
    const brand = [
      [167, 212, 222], // sky
      [222, 166, 188], // pink
      [222, 217, 166], // cream
    ];
    const cell = 16;
    const t = 0.6; // frozen frame of the hero wave

    function draw() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = host.clientWidth;
      const h = host.clientHeight;
      if (!w || !h) return;

      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.font = '11px ui-monospace, SFMono-Regular, Menlo, monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      const cols = Math.ceil(w / cell);
      const rows = Math.ceil(h / cell);
      ctx.clearRect(0, 0, w, h);

      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const wave = Math.sin(x * 0.32 + y * 0.22 - t);
          if (wave < 0.12) continue;
          const a = (wave - 0.12) / 0.88;
          let r = 255, g = 255, b = 255, alpha = 0.05 + a * 0.18;
          if (wave > 0.9) {
            const c = brand[(x + y) % 3];
            r = c[0]; g = c[1]; b = c[2];
            alpha = 0.3 + (wave - 0.9) * 3;
          }
          const glyph = glyphs[(x * 7 + y * 13) % glyphs.length];
          ctx.fillStyle = `rgba(${r},${g},${b},${alpha.toFixed(3)})`;
          ctx.fillText(glyph, x * cell + cell / 2, y * cell + cell / 2);
        }
      }
    }

    draw();
    let rt = 0;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(draw, 150);
    });
  });
</script>
