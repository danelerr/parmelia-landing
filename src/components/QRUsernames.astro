---
const cards = [
  { mark: '01', title: 'Apunta la cámara', desc: 'El pago abre con el receptor y el monto correctos.' },
  { mark: '02', title: 'Escribe un nombre', desc: 'Pagas a una persona, no a una dirección imposible.' },
  { mark: '03', title: 'Pega el link', desc: 'Sirve para vender por DM, grupos, eventos o comunidades.' },
];
---

<section id="qr-usernames" class="landing-section" style="background-color: var(--color-sky);">
  <div class="landing-shell">
    <div class="copy-stack" data-reveal>
      <span class="section-eyebrow">QR y usernames</span>
      <h2 class="section-title">Pagar no debería pedir una dirección imposible.</h2>
      <p class="section-copy">
        Escanea un QR, escribe un username o comparte tu perfil. Parmelia deja claro quién recibe, cuánto se paga y cuándo queda listo.
      </p>
    </div>

    <div class="qr-showcase" data-reveal>
      <div class="qr-box">
        <div class="scan-line" aria-hidden="true"></div>
        <svg class="qr-real" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="180" height="180" fill="#fff" />
          <rect x="10" y="10" width="44" height="44" fill="#121212" />
          <rect x="18" y="18" width="28" height="28" fill="#fff" />
          <rect x="26" y="26" width="12" height="12" fill="#121212" />
          <rect x="126" y="10" width="44" height="44" fill="#121212" />
          <rect x="134" y="18" width="28" height="28" fill="#fff" />
          <rect x="142" y="26" width="12" height="12" fill="#121212" />
          <rect x="10" y="126" width="44" height="44" fill="#121212" />
          <rect x="18" y="134" width="28" height="28" fill="#fff" />
          <rect x="26" y="142" width="12" height="12" fill="#121212" />
          <rect x="70" y="14" width="10" height="10" fill="#121212" />
          <rect x="92" y="14" width="20" height="10" fill="#121212" />
          <rect x="68" y="34" width="20" height="10" fill="#121212" />
          <rect x="104" y="36" width="10" height="20" fill="#121212" />
          <rect x="70" y="70" width="10" height="20" fill="#121212" />
          <rect x="92" y="68" width="10" height="10" fill="#121212" />
          <rect x="116" y="66" width="20" height="10" fill="#121212" />
          <rect x="150" y="70" width="10" height="20" fill="#121212" />
          <rect x="64" y="96" width="22" height="10" fill="#121212" />
          <rect x="98" y="94" width="10" height="24" fill="#121212" />
          <rect x="124" y="94" width="34" height="10" fill="#121212" />
          <rect x="70" y="126" width="10" height="10" fill="#121212" />
          <rect x="92" y="126" width="22" height="10" fill="#121212" />
          <rect x="128" y="124" width="10" height="28" fill="#121212" />
          <rect x="152" y="120" width="18" height="10" fill="#121212" />
          <rect x="64" y="152" width="18" height="10" fill="#121212" />
          <rect x="96" y="150" width="10" height="20" fill="#121212" />
          <rect x="116" y="162" width="34" height="8" fill="#121212" />
          <rect x="160" y="150" width="10" height="20" fill="#121212" />
        </svg>
        <p class="mt-4 text-center text-2xl font-bold leading-tight text-[#121212]">QR</p>
      </div>

      <svg class="network-sketch" viewBox="0 0 360 260" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="360" height="260" fill="transparent" />
        <line class="net-line" x1="58" y1="52" x2="178" y2="130" stroke="#121212" stroke-opacity=".45" stroke-width="2" />
        <line class="net-line" x1="178" y1="130" x2="302" y2="78" stroke="#121212" stroke-opacity=".45" stroke-width="2" style="animation-delay:.7s" />
        <line class="net-line" x1="102" y1="212" x2="178" y2="130" stroke="#121212" stroke-opacity=".45" stroke-width="2" style="animation-delay:1.2s" />
        <line class="net-line" x1="58" y1="52" x2="102" y2="212" stroke="#121212" stroke-opacity=".18" stroke-width="2" style="animation-delay:.3s" />
        <circle class="net-node" cx="58" cy="52" r="7" fill="#DEA6BC" />
        <circle class="net-node" cx="178" cy="130" r="10" fill="#121212" />
        <circle class="net-node" cx="302" cy="78" r="7" fill="#DED9A6" />
        <circle class="net-node" cx="102" cy="212" r="7" fill="#A7D4DE" />
        <text x="178" y="226" text-anchor="middle" fill="#121212" fill-opacity=".56" font-size="16" font-weight="800">QR, username y link</text>
      </svg>
    </div>

    <div class="qr-action-grid" data-reveal-stagger>
      {cards.map((card) => (
        <article class="qr-action-card">
          <span class="card-mark">{card.mark}</span>
          <h3 class="card-title">{card.title}</h3>
          <p class="card-copy">{card.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
