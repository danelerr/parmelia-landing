---
import { getLang } from '../i18n';

const lang = getLang(Astro.currentLocale);
const t = {
  es: {
    title: 'Pagar con QR, como ya lo haces.',
    copy: 'El QR ya es parte del día a día en Bolivia. Parmelia lo lleva a dólares digitales: escanea, escribe un username o comparte tu perfil. Siempre queda claro quién recibe y cuánto.',
    steps: [
      { dot: 'var(--glow-sky)', title: 'Apunta la cámara', desc: 'El pago abre con el receptor y el monto correctos.' },
      { dot: 'var(--glow-pink)', title: 'Escribe un nombre', desc: 'Pagas a una persona, no a una dirección imposible.' },
      { dot: 'var(--glow-gold)', title: 'Pega el link', desc: 'Sirve para vender por DM, grupos, eventos o comunidades.' },
    ],
  },
  en: {
    title: 'Pay with QR, like you already do.',
    copy: 'QR is already part of everyday life in Bolivia. Parmelia brings it to digital dollars: scan, type a username or share your profile. It’s always clear who receives and how much.',
    steps: [
      { dot: 'var(--glow-sky)', title: 'Point your camera', desc: 'The payment opens with the right recipient and amount.' },
      { dot: 'var(--glow-pink)', title: 'Type a name', desc: 'You pay a person, not an impossible address.' },
      { dot: 'var(--glow-gold)', title: 'Paste the link', desc: 'Great for selling by DM, groups, events or communities.' },
    ],
  },
}[lang];
const steps = t.steps;

/* Decorative QR matrix — looks like a real QR (finders, timing, alignment,
   dense deterministic data). Not meant to be scannable. */
const QR_N = 25;
const qr: boolean[][] = Array.from({ length: QR_N }, () => Array(QR_N).fill(false));

const placeFinder = (top: number, left: number) => {
  for (let i = 0; i < 7; i++)
    for (let j = 0; j < 7; j++) {
      const edge = i === 0 || i === 6 || j === 0 || j === 6;
      const core = i >= 2 && i <= 4 && j >= 2 && j <= 4;
      qr[top + i][left + j] = edge || core;
    }
};
placeFinder(0, 0);
placeFinder(0, QR_N - 7);
placeFinder(QR_N - 7, 0);

for (let i = 8; i < QR_N - 8; i++) {
  qr[6][i] = i % 2 === 0;
  qr[i][6] = i % 2 === 0;
}

const ac = QR_N - 7; // alignment center (bottom-right area)
for (let i = -2; i <= 2; i++)
  for (let j = -2; j <= 2; j++) qr[ac + i][ac + j] = Math.max(Math.abs(i), Math.abs(j)) !== 1;

const reserved = (r: number, c: number) =>
  (r < 8 && c < 8) ||
  (r < 8 && c >= QR_N - 8) ||
  (r >= QR_N - 8 && c < 8) ||
  r === 6 ||
  c === 6 ||
  (r >= ac - 2 && r <= ac + 2 && c >= ac - 2 && c <= ac + 2);

let qstate = 0x6d2b79f5;
const qrand = () => {
  qstate |= 0;
  qstate = (qstate + 0x6d2b79f5) | 0;
  let z = Math.imul(qstate ^ (qstate >>> 15), 1 | qstate);
  z = (z + Math.imul(z ^ (z >>> 7), 61 | z)) ^ z;
  return ((z ^ (z >>> 14)) >>> 0) / 4294967296;
};
for (let r = 0; r < QR_N; r++)
  for (let c = 0; c < QR_N; c++) if (!reserved(r, c)) qr[r][c] = qrand() < 0.5;

let qrPath = '';
for (let r = 0; r < QR_N; r++)
  for (let c = 0; c < QR_N; c++) if (qr[r][c]) qrPath += `M${c} ${r}h1v1h-1z`;
---

<section id="qr-usernames" class="landing-section">
  <div class="landing-shell">
    <div class="split is-reverse" data-reveal>
      <div class="split-visual">
        <div class="stage glow-sky">
          <div class="qr-box" style="width:min(240px,100%); margin:0 auto; box-shadow:none;">
            <div class="scan-line" aria-hidden="true"></div>
            <svg class="qr-real" viewBox="-1 -1 27 27" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="-1" y="-1" width="27" height="27" fill="#fff" />
              <path d={qrPath} fill="#0A0A0B" />
            </svg>
          </div>
          <div style="display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin-top:18px;">
            <span class="pill">@daniel</span>
            <span class="pill">parmelia.me/daniel</span>
          </div>
        </div>
      </div>

      <div class="split-copy">
        <h2 class="section-title">{t.title}</h2>
        <p class="section-copy">{t.copy}</p>

        <div class="point-list" data-reveal-stagger>
          {steps.map((step) => (
            <div class="point-row">
              <span class="dot" style={`background:${step.dot}; color:${step.dot};`}></span>
              <p><strong style="color:var(--color-text); font-weight:600;">{step.title}.</strong> {step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
