---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import ProofBar from '../components/ProofBar.astro';
import BrowserFirst from '../components/BrowserFirst.astro';
import PaymentLinks from '../components/PaymentLinks.astro';
import QRUsernames from '../components/QRUsernames.astro';
import NoFees from '../components/NoFees.astro';
import MultiAsset from '../components/MultiAsset.astro';
import Swaps from '../components/Swaps.astro';
import EarnMode from '../components/EarnMode.astro';
import CrossChain from '../components/CrossChain.astro';
import Control from '../components/Control.astro';
import Faq from '../components/Faq.astro';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main>
    <Hero />
    <ProofBar />
    <BrowserFirst />
    <PaymentLinks />
    <QRUsernames />
    <NoFees />
    <MultiAsset />
    <Swaps />
    <EarnMode />
    <CrossChain />
    <Control />
    <Faq />
    <CTAFinal />
  </main>

  <Footer />
</Layout>

<!-- Scroll Reveal Animation Script using Motion.js -->
<script>
  import { animate, inView } from 'motion';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      inView(el, () => {
        animate(
          el,
          {
            opacity: [0, 1],
            transform: ['translateY(26px) scale(0.985)', 'translateY(0) scale(1)'],
            filter: ['blur(4px)', 'blur(0px)'],
          },
          { duration: 0.95, ease: [0.16, 1, 0.3, 1] }
        );
      }, { margin: '0px 0px -80px 0px' });
    });

    document.querySelectorAll<HTMLElement>('[data-reveal-stagger]').forEach((el) => {
      inView(el, () => {
        Array.from(el.children).forEach((child, i) => {
          animate(
            child as HTMLElement,
            {
              opacity: [0, 1],
              transform: ['translateY(18px)', 'translateY(0)'],
            },
            { duration: 0.7, delay: i * 0.08, ease: [0.16, 1, 0.3, 1] }
          );
        });
      }, { margin: '0px 0px -60px 0px' });
    });

    document.querySelectorAll<HTMLElement>('[data-float]').forEach((el, index) => {
      animate(
        el,
        {
          transform: ['translateY(0px)', 'translateY(-7px)', 'translateY(0px)'],
        },
        { duration: 5.8 + index * 0.4, repeat: Infinity, ease: 'easeInOut' }
      );
    });

  } else {
    document.querySelectorAll<HTMLElement>('[data-reveal], [data-reveal-stagger] > *').forEach((el) => {
      el.style.opacity = '1';
      el.style.transform = 'none';
      el.style.filter = 'none';
    });
  }
</script>
